{
  "buildCommand": "cd my-website && npm install && npm run build",
  "outputDirectory": "my-website/build",
  "devCommand": "cd my-website && npm run start",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
